{
  "manifest_version": 3,
  "name": "QR Code Generator & Scanner - Logo, Offline & Free",
  "version": "1.2.1",
  "description": "Free QR code generator & scanner with logo embedding, custom colors, URL editor, history. 100% offline, no ads, no sign-up.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "description": "Open QR Code Generator",
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "QR Code Generator & Scanner",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
